# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Price IDs — create Products in Stripe Dashboard, then copy the Price IDs here
# One-time payment prices:
STRIPE_PRICE_TEAMS=price_...
STRIPE_PRICE_CAMPS=price_...
STRIPE_PRICE_EKUZO100=price_...

# EKUZO Teams — 4 × monthly installments
# Create a Subscription price in Stripe with:
#   - Billing period: Monthly
#   - Set a fixed billing cycle count of 4 in the payment link or via the API
STRIPE_PRICE_TEAMS_INSTALLMENTS=price_...

# ─── Site ─────────────────────────────────────────────────────────────────────
# Used to build absolute URLs for Stripe success/cancel redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
